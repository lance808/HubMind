{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "composite": true,
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "jsx": "react-jsx",
    "types": ["node"],
    "paths": {
      "@/*": ["./apps/desktop/src/renderer/*"],
      "@hubmind/core": ["./packages/core/src"],
      "@hubmind/core/*": ["./packages/core/src/*"],
      "@hubmind/shared": ["./packages/shared/src"],
      "@hubmind/shared/*": ["./packages/shared/src/*"],
      "@hubmind/ui": ["./packages/ui/src"],
      "@hubmind/ui/*": ["./packages/ui/src/*"]
    }
  },
  "include": [
    "apps/desktop/src/renderer/**/*",
    "packages/ui/src/**/*",
    "packages/shared/src/**/*",
    "packages/core/src/**/*",
    "env.d.ts"
  ]
}
